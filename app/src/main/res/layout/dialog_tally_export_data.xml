<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="@dimen/spacing_micro"
    android:paddingEnd="24dp"
    android:paddingBottom="@dimen/spacing_micro">

    <TextView
        android:id="@+id/tvStartDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="开始日期"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/app_text_size_normal" />

    <TextView
        android:id="@+id/tvStartDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_micro"
        android:background="@drawable/bg_touchable_white"
        android:drawableEnd="@drawable/ic_date_range"
        android:gravity="center_vertical"
        android:hint="请选择开始日期"
        android:padding="@dimen/padding_normal"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/app_text_size_normal" />

    <TextView
        android:id="@+id/tvEndDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_normal"
        android:text="结束日期"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/app_text_size_normal" />

    <TextView
        android:id="@+id/tvEndDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_micro"
        android:background="@drawable/bg_touchable_white"
        android:drawableEnd="@drawable/ic_date_range"
        android:gravity="center_vertical"
        android:hint="请选择结束日期"
        android:padding="@dimen/padding_normal"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/app_text_size_normal" />

    <TextView
        android:id="@+id/tvFormatLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_normal"
        android:text="导出格式"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/app_text_size_normal" />

    <RadioGroup
        android:id="@+id/rgFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_micro"
        android:checkedButton="@id/rbCsv"
        android:orientation="horizontal"
        android:gravity="center">

        <RadioButton
            android:id="@+id/rbCsv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CSV"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/app_text_size_normal" />

        <RadioButton
            android:id="@+id/rbExcel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_normal"
            android:text="Excel"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/app_text_size_normal" />
    </RadioGroup>

</LinearLayout>
