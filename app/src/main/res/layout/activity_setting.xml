<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data class=".module.setting.SettingActivityBinding">

        <variable
            name="activity"
            type="android.app.Activity" />

        <variable
            name="vm"
            type="com.coderpage.mine.app.tally.module.setting.SettingViewModel" />

    </data>

    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        tools:context=".app.tally.module.setting.SettingActivity">

        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar" />

        <android.support.v4.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_micro"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintVertical_bias="1.0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <android.support.constraint.ConstraintLayout
                    android:id="@+id/lyAiSetting"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_touchable_white"
                    android:paddingStart="@dimen/padding_normal"
                    android:paddingEnd="@dimen/padding_normal">

                    <TextView
                        android:id="@+id/tvAiSettingTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="@string/tally_setting_ai_title"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvAiKeyLabel"
                        android:layout_width="80dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="@dimen/spacing_normal"
                        android:gravity="left|center_vertical"
                        android:text="@string/tally_setting_ai_key"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvAiSettingTitle" />

                    <EditText
                        android:id="@+id/etApiKey"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:hint="@string/tally_setting_ai_key_hint"
                        android:inputType="text"
                        android:maxLength="300"
                        android:text="@={vm.apiKey}"
                        app:layout_constraintBottom_toBottomOf="@id/tvAiKeyLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvAiKeyLabel"
                        app:layout_constraintTop_toTopOf="@id/tvAiKeyLabel" />

                    <TextView
                        android:id="@+id/tvAiModelLabel"
                        android:layout_width="80dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="left|center_vertical"
                        android:text="@string/tally_setting_ai_model"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvAiKeyLabel" />

                    <EditText
                        android:id="@+id/etAiModel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:hint="@string/tally_setting_ai_model_name"
                        android:inputType="text"
                        android:maxLength="300"
                        android:text="@={vm.aiModel}"
                        app:layout_constraintBottom_toBottomOf="@id/tvAiModelLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvAiModelLabel"
                        app:layout_constraintTop_toTopOf="@id/tvAiModelLabel" />

                    <TextView
                        android:id="@+id/tvAiSettingTip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/tally_setting_ai_description"
                        android:textColor="@color/appTextColorThird"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvAiModelLabel" />

                    <View
                        style="@style/Divider"
                        android:layout_width="match_parent"
                        android:layout_height="3px"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="5dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvAiSettingTip"
                        tools:layout_editor_absoluteX="16dp" />
                    <Button
                        android:id="@+id/btnAiSetting"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:text="配置 AI API" />
                </android.support.constraint.ConstraintLayout>

                                <!-- Notion 同步设置 -->
                <android.support.constraint.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_micro"
                    android:background="@drawable/bg_touchable_white"
                    android:paddingStart="@dimen/padding_normal"
                    android:paddingEnd="@dimen/padding_normal">

                    <TextView
                        android:id="@+id/tvNotionSyncTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="Notion 同步"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNotionTokenLabel"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_normal"
                        android:gravity="left|center_vertical"
                        android:text="Token"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotionSyncTitle" />

                    <EditText
                        android:id="@+id/etNotionToken"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:hint="secret_xxx..."
                        android:inputType="text"
                        android:maxLength="200"
                        android:text="@={vm.notionToken}"
                        app:layout_constraintBottom_toBottomOf="@id/tvNotionTokenLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvNotionTokenLabel"
                        app:layout_constraintTop_toTopOf="@id/tvNotionTokenLabel" />

                    <TextView
                        android:id="@+id/tvDatabaseIdLabel"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="left|center_vertical"
                        android:text="Database ID"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotionTokenLabel" />

                    <EditText
                        android:id="@+id/etDatabaseId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:hint="Notion 数据库 ID"
                        android:inputType="text"
                        android:maxLength="100"
                        android:text="@={vm.notionDatabaseId}"
                        app:layout_constraintBottom_toBottomOf="@id/tvDatabaseIdLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvDatabaseIdLabel"
                        app:layout_constraintTop_toTopOf="@id/tvDatabaseIdLabel" />

                    <Button
                        android:id="@+id/btnSyncNow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:layout_marginEnd="@dimen/spacing_normal"
                        android:text="立即同步"
                        app:layout_constraintEnd_toStartOf="@id/btnCreateDatabase"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDatabaseIdLabel" />

                    <Button
                        android:id="@+id/btnCreateDatabase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="创建数据库"
                        app:layout_constraintBottom_toBottomOf="@id/btnSyncNow"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/btnSyncNow" />

                    <!-- 启动时自动同步开关 -->
                    <TextView
                        android:id="@+id/tvAutoSyncLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="启动时自动同步"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintEnd_toStartOf="@id/switchAutoSync"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnSyncNow" />

                    <Switch
                        android:id="@+id/switchAutoSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="@={vm.autoSyncEnabled}"
                        app:layout_constraintBottom_toBottomOf="@id/tvAutoSyncLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvAutoSyncLabel" />

                    <TextView
                        android:id="@+id/tvNotionSyncTip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_normal"
                        android:layout_marginBottom="@dimen/spacing_large"
                        android:text="配置 Notion Integration Token 和 Database ID 后即可开启同步功能"
                        android:textColor="@color/appTextColorThird"
                        android:textSize="@dimen/app_text_size_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnSyncNow" />

                    <View
                        style="@style/Divider"
                        android:layout_width="match_parent"
                        android:layout_height="3px"
                        android:layout_marginTop="@dimen/spacing_large"
                        app:layout_constraintTop_toBottomOf="@id/tvNotionSyncTip"
                        tools:layout_editor_absoluteX="16dp" />
                </android.support.constraint.ConstraintLayout>

                <!-- 短信识别部分 -->
                <android.support.constraint.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_micro"
                    android:background="@drawable/bg_touchable_white"
                    android:paddingStart="@dimen/padding_normal"
                    android:paddingEnd="@dimen/padding_normal">

                    <TextView
                        android:id="@+id/tvSmsRecognitionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="短信识别"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvRecognitionSwitchLabel"
                        android:layout_width="80dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="left|center_vertical"
                        android:text="是否开启"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvSmsRecognitionTitle" />

                    <Button
                        android:id="@+id/btnRecognitionSwitch"
                        android:layout_width="300dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:text="开启"
                        app:layout_constraintBottom_toBottomOf="@id/tvRecognitionSwitchLabel"
                        app:layout_constraintStart_toEndOf="@id/tvRecognitionSwitchLabel"
                        app:layout_constraintTop_toTopOf="@id/tvRecognitionSwitchLabel" />

                    <TextView
                        android:id="@+id/tvDetectionListLabel"
                        android:layout_width="80dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="left|center_vertical"
                        android:text="检测名单"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvRecognitionSwitchLabel" />

                    <EditText
                        android:id="@+id/etDetectionList"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:hint="多个号码用逗号分隔"
                        android:inputType="text"
                        android:maxLength="300"
                        android:text="@={vm.detectionList}"
                        app:layout_constraintBottom_toBottomOf="@id/tvDetectionListLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvDetectionListLabel"
                        app:layout_constraintTop_toTopOf="@id/tvDetectionListLabel" />

                    <TextView
                        android:id="@+id/tvSmsRecognitionTip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="@dimen/spacing_large"
                        android:text="使用此功能可以从短信中识别支出收入,该功能限制较多,可靠度较差"
                        android:textColor="@color/appTextColorThird"
                        android:textSize="@dimen/app_text_size_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDetectionListLabel" />

                    <View
                        style="@style/Divider"
                        android:layout_width="match_parent"
                        android:layout_height="3px"
                        android:layout_marginTop="70dp"
                        app:layout_constraintTop_toBottomOf="@id/tvDetectionListLabel"
                        tools:layout_editor_absoluteX="16dp" />
                </android.support.constraint.ConstraintLayout>
                <!-- 数据清除部分 -->
                <android.support.constraint.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_micro"
                    android:background="@drawable/bg_touchable_white"
                    android:paddingStart="@dimen/padding_normal"
                    android:paddingEnd="@dimen/padding_normal">

                    <TextView
                        android:id="@+id/tvDataClearTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="数据清除"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvDataClearDescLabel"
                        android:layout_width="80dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="left|center_vertical"
                        android:text="清除所有"
                        android:textColor="@color/appTextColorPrimary"
                        android:textSize="@dimen/app_text_size_large"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDataClearTitle" />

                    <Button
                        android:id="@+id/btnClearData"
                        android:layout_width="300dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="@dimen/spacing_normal"
                        android:text="清除"
                        app:layout_constraintBottom_toBottomOf="@id/tvDataClearDescLabel"
                        app:layout_constraintStart_toEndOf="@id/tvDataClearDescLabel"
                        app:layout_constraintTop_toTopOf="@id/tvDataClearDescLabel" />

                    <TextView
                        android:id="@+id/tvDataClearTip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="@dimen/spacing_large"
                        android:text="使用此操作将永久删除数据，无法恢复"
                        android:textColor="@color/appTextColorThird"
                        android:textSize="@dimen/app_text_size_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDataClearDescLabel" />

                    <View
                        style="@style/Divider"
                        android:layout_width="match_parent"
                        android:layout_height="3px"
                        android:layout_marginTop="50dp"
                        app:layout_constraintTop_toBottomOf="@id/tvDataClearDescLabel"
                        tools:layout_editor_absoluteX="16dp" />
                </android.support.constraint.ConstraintLayout>

            </LinearLayout>

        </android.support.v4.widget.NestedScrollView>

    </android.support.constraint.ConstraintLayout>

</layout>